# ==========================================
# ReachNext Unified Environment Variables
# ==========================================
# This file serves as a reference for all required environment variables
# across the monorepo. Copy the relevant sections to the respective 
# .env files in the /crm and /channel-service directories.

# ==========================================
# CRM Service (.env inside /crm)
# ==========================================

# -- Database Connection --
# The primary connection string for Prisma to connect to PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/reachnext"
# Optional: Direct connection string if using a connection pooler like Supavisor/PgBouncer
DIRECT_URL="postgresql://user:password@localhost:5432/reachnext"

# -- Core Services --
# URL where the CRM should dispatch campaigns to the Channel Service
CHANNEL_SERVICE_URL="http://localhost:3001"
# URL where the Channel Service should send delivery receipts back to the CRM
CRM_WEBHOOK_URL="http://localhost:3000/api/webhooks/receipt"

# -- AI Integrations (Requires at least one) --
# Your API key for Groq Cloud
GROQ_API_KEY="your_groq_api_key_here"
# Your API key for Google Gemini
GEMINI_API_KEY="your_gemini_api_key_here"

# -- AI Configuration & Routing --
# Global default provider (Options: groq | gemini). Default is groq.
AI_PROVIDER="groq"
# Optional fallback provider if the primary provider experiences rate limits or 5xx errors
# AI_FALLBACK_PROVIDER="gemini"

# (Optional) Task-Level AI Provider Overrides
# You can route specific AI tasks to different models based on latency/reasoning needs.
# AI_PROVIDER_SEGMENTATION="groq"
# AI_PROVIDER_COMPARE_INSIGHTS="groq"
# AI_PROVIDER_SEGMENT_INSIGHTS="groq"
# AI_PROVIDER_SELF_CORRECTION="groq"
# AI_PROVIDER_CAMPAIGN_INSIGHT="gemini"
# AI_PROVIDER_OPPORTUNITY_EXPLANATIONS="gemini"

# (Optional) Specific Model Overrides
# GROQ_MODEL="llama-3.3-70b-versatile"
# GEMINI_MODEL="gemini-2.5-pro"


# ==========================================
# Channel Service (.env inside /channel-service)
# ==========================================

# The port where the Channel Service will run
PORT=3001

# The fallback webhook URL to send delivery receipts if none is provided in the payload
CRM_WEBHOOK_URL="http://localhost:3000/api/webhooks/receipt"
