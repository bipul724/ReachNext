# CRM (.env inside crm/)
DATABASE_URL=
DIRECT_URL=
GEMINI_API_KEY=
GROQ_API_KEY=
CHANNEL_SERVICE_URL=http://localhost:3001
CRM_WEBHOOK_URL=http://localhost:3000/api/webhooks/receipt

# ── AI Service Configuration ──
# Global default provider (groq | gemini). Default: groq
AI_PROVIDER=groq
# Optional fallback provider (used on rate limit, timeout, or 5xx)
# AI_FALLBACK_PROVIDER=gemini

# ── Task-Level Provider Routing (Optional) ──
# Override the global provider for specific tasks.
# If unset, AI_PROVIDER is used for that task.
# AI_PROVIDER_SEGMENTATION=groq
# AI_PROVIDER_COMPARE_INSIGHTS=groq
# AI_PROVIDER_SEGMENT_INSIGHTS=groq
# AI_PROVIDER_SELF_CORRECTION=groq
# AI_PROVIDER_CAMPAIGN_INSIGHT=gemini
# AI_PROVIDER_OPPORTUNITY_EXPLANATIONS=gemini

# ── Optional Model Overrides ──
# GROQ_MODEL=llama-3.3-70b-versatile
# GEMINI_MODEL=gemini-2.5-pro

# Channel Service (.env inside channel-service/)
PORT=3001
CRM_WEBHOOK_URL=http://localhost:3000/api/webhooks/receipt

